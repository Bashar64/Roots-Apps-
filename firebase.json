{
  "hosting": {
    "site": "roots-apps",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/html/index.html"
      },
      {
        "source": "/roots_cod_dashboard",
        "destination": "/html/roots_cod_dashboard.html"
      },
      {
        "source": "/roots_cod_dashboard.html",
        "destination": "/html/roots_cod_dashboard.html"
      },
      {
        "source": "/Roots Weekly Cycle Dashboard",
        "destination": "/html/Roots Weekly Cycle Dashboard.html"
      },
      {
        "source": "/Roots Weekly Cycle Dashboard.html",
        "destination": "/html/Roots Weekly Cycle Dashboard.html"
      },
      {
        "source": "/pickup_tracker",
        "destination": "/html/pickup_tracker.html"
      },
      {
        "source": "/pickup_tracker.html",
        "destination": "/html/pickup_tracker.html"
      },
      {
        "source": "/admin",
        "destination": "/html/admin.html"
      },
      {
        "source": "/admin.html",
        "destination": "/html/admin.html"
      },
      {
        "source": "/cases_tracker",
        "destination": "/html/cases_tracker.html"
      },
      {
        "source": "/cases_tracker.html",
        "destination": "/html/cases_tracker.html"
      },
      {
        "source": "/shift_tracker",
        "destination": "/html/shift_tracker.html"
      },
      {
        "source": "/shift_tracker.html",
        "destination": "/html/shift_tracker.html"
      }
    ],
    "cleanUrls": true,
    "trailingSlash": false
  }
}
